{
  "name": "sharemate",
  "version": "0.1.0",
  "private": true,
  "description": "Application de partage de matériel entre particuliers (équipements, réservations, usage, frais partagés)",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspaces",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run build --workspaces",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace web",
    "start": "npm run start --workspace server"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@vitest/coverage-v8": "^3.1.4",
    "eslint": "^9.27.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.4"
  }
}
