# Répertoire des données persistantes (SQLite + justificatifs).
DATA_DIR=./data
# Chemins fins (par défaut dérivés de DATA_DIR).
# DATABASE_PATH=./data/sharemate.sqlite
# UPLOADS_DIR=./data/uploads
# Répertoire du front compilé servi en production.
# WEB_DIST_DIR=./web/dist
PORT=3000
# En production : active cookie Secure, trustProxy et logs JSON niveau info.
# NODE_ENV=production

# --- Notifications push (optionnel) ---
# Sans ces variables, seul le centre de notifications in-app fonctionne (aucune infra requise).
# Voir docs/notifications.md pour la procédure complète.
#
# Web Push (PWA) — générer avec : npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:contact@exemple.fr
#
# Push natif Android (FCM) — JSON du compte de service Firebase (sur une seule ligne).
# FCM_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
